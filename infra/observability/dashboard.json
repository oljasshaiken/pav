{
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Claims DLQ Depth",
        "view": "singleValue",
        "region": "us-east-1",
        "stat": "Maximum",
        "period": 60,
        "metrics": [
          [
            "AWS/SQS",
            "ApproximateNumberOfMessagesVisible",
            "QueueName",
            "pav-edi-claims-dlq.fifo"
          ]
        ]
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Lambda Errors",
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1",
        "stat": "Sum",
        "period": 300,
        "metrics": [
          ["AWS/Lambda", "Errors", "FunctionName", "pav-edi-dispatch"],
          ["...", "pav-edi-rules"],
          ["...", "pav-edi-transformer"],
          ["...", "pav-edi-persist"],
          ["...", "pav-edi-publish-dlq"]
        ]
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 24,
      "height": 6,
      "properties": {
        "title": "Step Functions Failed",
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1",
        "stat": "Sum",
        "period": 300,
        "metrics": [
          [
            "AWS/States",
            "ExecutionsFailed",
            "StateMachineArn",
            "pav-edi-outbound-claim"
          ],
          [
            "...",
            "pav-edi-inbound-ack"
          ]
        ]
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 12,
      "width": 24,
      "height": 6,
      "properties": {
        "title": "DLQ Alerts (Logs Insights)",
        "region": "us-east-1",
        "query": "fields @timestamp, claim_id, payer_id, code, message, rule_id | filter event = \"dlq_alert\" | sort @timestamp desc | limit 50",
        "view": "table"
      }
    }
  ]
}
